{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run Extension",
      "type": "extensionHost",
      "request": "launch",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}/packages/vscode-radiant"
      ],
      "outFiles": [
        "${workspaceFolder}/packages/vscode-radiant/dist/**/*.js"
      ],
      "preLaunchTask": "bun: build-extension"
    }
  ]
}
