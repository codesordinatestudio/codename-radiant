{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Radiant DSL",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#decorators"
    },
    {
      "include": "#types"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.radiant",
          "match": "//.*$"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.radiant",
          "match": "\\b(config|core|adminUI|security|monitoring|collection|fields|auth|realtime|cache)\\b"
        },
        {
          "name": "constant.language.boolean.radiant",
          "match": "\\b(true|false)\\b"
        }
      ]
    },
    "strings": {
      "name": "string.quoted.double.radiant",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        {
          "name": "constant.character.escape.radiant",
          "match": "\\\\."
        }
      ]
    },
    "decorators": {
      "patterns": [
        {
          "name": "entity.name.function.decorator.radiant",
          "match": "@[a-zA-Z0-9_]+"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "support.type.radiant",
          "match": "\\b(string|email|password|text|link)\\b"
        }
      ]
    }
  },
  "scopeName": "source.radiant"
}
