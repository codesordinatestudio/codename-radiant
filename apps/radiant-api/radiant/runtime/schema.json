{
  "collections": [
    {
      "slug": "projects",
      "fields": [
        {
          "name": "projectId",
          "type": "text",
          "unique": true
        },
        {
          "name": "apiKey",
          "type": "text"
        },
        {
          "name": "targetDir",
          "type": "text"
        },
        {
          "name": "status",
          "type": "enum",
          "values": [
            "ready",
            "building",
            "failed"
          ],
          "default": "ready"
        }
      ]
    }
  ],
  "globals": [],
  "apiPrefix": "/api"
}