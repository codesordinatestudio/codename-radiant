config {
  apiPrefix: "/api"
}

collection projects {
  fields: {
    projectId: text @unique;
    apiKey: text;
    targetDir: text;
    status: ["ready", "building", "failed"] @default("ready");
  }
}

collection apiKeys {
  fields: {
    key: text @unique;
    ownerName: text;
    companyName: text;
    expiresAt: date;
  }
}
